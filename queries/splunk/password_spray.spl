``` [Auth] - Password Spray From Single Source — MITRE T1110.003
    One source IP failing against many DISTINCT accounts in a day. Breadth,
    not depth — this is what separates spray from single-account brute force. ```
index=auth sourcetype=login_events success=0
| bucket _time span=1d
| stats dc(username) AS accounts_targeted,
        count AS total_failures,
        values(username) AS usernames
    BY src_ip, _time
| where accounts_targeted>=5
| sort - accounts_targeted
